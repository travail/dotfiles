[user]
	name  = travail
	email = sawa.tomoyuki@gmail.com
	signingkey = F7F867AF7781AC2A
[alias]
	url = config --get remote.origin.url
	st = status
	co = checkout
	hist = log --oneline --graph --decorate
[color]
	ui = auto
[include]
	path = ~/.gitconfig.local
[core]
	editor = emacs
	untrackedCache = true
	pager = delta
	excludesFile = ~/.gitignore
[delta]
	navigate = true
	line-numbers = true
	side-by-side = true
[diff]
	colorMoved = default
[interactive]
	diffFilter = delta --color-only
[merge]
	ff = false
	conflictstyle = zdiff3
[push]
	autoSetupRemote = true
	default = current
[pull]
	ff = only
[fetch]
	prune = true
[rebase]
	autosquash = true
[url "git@github.com:"]
	insteadOf = https://github.com/
[gpg]
	program = /opt/homebrew/bin/gpg
[commit]
	gpgsign = true
[init]
	defaultBranch = main
[log]
	date = iso
[tag]
	sort = version:refname
[rerere]
	enabled = true
[maintenance]
	auto = true
