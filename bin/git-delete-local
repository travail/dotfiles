#!/bin/sh
# delete local branch(es) with fzf multi-select
branches=$(git for-each-ref --sort=-committerdate --format='%(refname:short)' refs/heads/ \
  | grep -v "^$(git symbolic-ref --short HEAD)$" \
  | fzf --prompt='delete> ' \
        --multi \
        --preview='git log --oneline --color=always -15 {}' \
        --preview-window=right:60%)
[ -n "$branches" ] && echo "$branches" | xargs git branch -d
