#!/bin/bash
set -euo pipefail
# fzf exits non-zero on cancel (Esc), if handles that without triggering set -e
if branches=$(git for-each-ref --sort=-committerdate --format='%(refname:short)' refs/heads/ \
  | grep -v "^$(git symbolic-ref --short HEAD)$" \
  | fzf --prompt='delete> ' \
        --multi \
        --preview='git log --oneline --color=always -15 {}' \
        --preview-window=right:60%); then
  echo "$branches" | xargs git branch -d
fi
