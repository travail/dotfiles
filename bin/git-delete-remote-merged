#!/bin/bash
set -euo pipefail
# fzf exits non-zero on cancel (Esc), if handles that without triggering set -e
if branches=$(git branch -r --merged \
  | grep -v 'HEAD' \
  | grep -vE 'origin/(master|main)$' \
  | sed 's|^ *origin/||' \
  | fzf --prompt='delete merged remote> ' \
        --multi \
        --preview='git log --oneline --color=always -15 origin/{}' \
        --preview-window=right:60%); then
  echo "$branches" | xargs -I{} git push origin --delete {}
fi
