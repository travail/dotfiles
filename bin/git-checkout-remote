#!/bin/bash
set -euo pipefail
# fzf exits non-zero on cancel (Esc), if handles that without triggering set -e
if branch=$(git for-each-ref --sort=-committerdate --format='%(refname:short)' refs/remotes/ \
  | grep -v HEAD \
  | fzf --prompt='remote> ' \
        --preview='git log --oneline --color=always -15 {}' \
        --preview-window=right:60%); then
  git checkout -b "${branch#origin/}" --track "$branch"
fi
