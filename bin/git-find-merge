#!/bin/bash
set -euo pipefail
# Find the merge commit that brought a given commit into a branch
if [ $# -lt 1 ]; then
  echo "usage: git find-merge <commit> [<branch>]" >&2
  exit 1
fi
commit=$1
branch=${2:-HEAD}
(git rev-list "$commit".."$branch" --ancestry-path | cat -n; \
 git rev-list "$commit".."$branch" --first-parent | cat -n) \
  | sort -k2 -s | uniq -f1 -d | sort -n | tail -1 | cut -f2
